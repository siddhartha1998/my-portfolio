// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Guestbook {
  id        String   @id @default(cuid())
  email     String
  body      String
  createdBy String
  createdAt DateTime @default(now())
}

model Contact {
  id        String   @id @default(cuid())
  name      String
  email     String
  message   String
  createdAt DateTime @default(now())
}

model Analytics {
  id        String   @id @default(cuid())
  page      String
  views     Int      @default(0)
  updatedAt DateTime @updatedAt
}

model BlogPost {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  excerpt   String
  content   String   @db.Text
  published Boolean  @default(false)
  date      DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Project {
  id          String   @id @default(cuid())
  title       String
  description String
  tech        String[] // Array of strings for tech stack
  github      String?
  demo        String?
  image       String?  // Optional image URL
  order       Int      @default(0) // For custom sorting
  createdAt   DateTime @default(now())
}
